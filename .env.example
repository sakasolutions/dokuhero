# Kopieren nach .env.local und Werte setzen.

# NextAuth – auf dem Produktionsserver: kanonische HTTPS-URL (keine IP:Port)
NEXTAUTH_URL=https://dokuhero.de
NEXTAUTH_SECRET=

# Lokal typischerweise:
# NEXTAUTH_URL=http://localhost:3000

OPENAI_API_KEY=
RESEND_API_KEY=
MAIL_FROM=

# Öffentliche Basis-URL für Links in E-Mails (Reset, Willkommen)
NEXT_PUBLIC_APP_URL=https://dokuhero.de
# oder APP_URL=https://dokuhero.de

DB_HOST=
DB_USER=
DB_PASSWORD=
DB_NAME=

# Admin-Panel: E-Mail eines Betriebs-Kontos mit Vollzugriff /admin
ADMIN_EMAIL=

# Geheimer Token für Cron-Endpunkte (Authorization: Bearer …)
# z. B. abo-check, bewertung, auto-archiv (/api/cron/*)
CRON_SECRET=

# Optional: Nur diese Login-E-Mails dürfen Protokolle freigeben/PDF erzeugen (kommagetrennt).
# Leer oder auskommentiert = jeder Nutzer des Betriebs (bis echtes Rollen-System).
# PROTOKOLL_FREIGABE_EMAILS=chef@firma.de,leitung@firma.de

# Optional: PDF/Fotos auf dem Server (cwd ≠ App-Verzeichnis)
# DOKUHERO_PUBLIC_DIR=/var/www/dokuhero/public
# FOTOS_UPLOAD_DIR=/var/www/dokuhero/public/uploads/fotos
